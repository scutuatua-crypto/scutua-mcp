# ================================================
# Scutua-MCP — .env.example
# Copy to .env and fill in your values
# DO NOT commit .env to git!
# ================================================

# Priority 1: Free APIs
COINGECKO_API_KEY=your_coingecko_api_key
CMC_API_KEY=your_coinmarketcap_api_key
DUNE_API_KEY=your_dune_api_key
HELIUS_API_KEY=your_helius_api_key
ALCHEMY_API_KEY=your_alchemy_api_key
ETHERSCAN_API_KEY=your_etherscan_api_key
BSC_API_KEY=your_bscscan_api_key
OPTIMISM_API_KEY=your_optimism_api_key
LUNARCRUSH_API_KEY=your_lunarcrush_api_key
GH_TOKEN=your_github_token

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Priority 2: Paid APIs
NANSEN_API_KEY=your_nansen_api_key
BIRDEYE_API_KEY=your_birdeye_api_key
OPENSEA_API_KEY=your_opensea_api_key

# Wallet addresses (public — safe to fill)
WALLET_ADDRESS=your_evm_wallet_address
TON_WALLET_ADDRESS=your_ton_wallet_address
SOLANA_WALLET_ADDRESS=your_solana_wallet_address

# Render
MCP_URL=https://scutua-mcp.onrender.com/mcp
PORT=3000
